# Runtime
NODE_ENV=production
PORT=5000

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRE=7d

# Initial admin bootstrap (optional but recommended for first deploy)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password

# CORS
# Single origin (Vercel production URL)
FRONTEND_URL=https://your-project.vercel.app
# Optional multiple origins (comma-separated)
# FRONTEND_URLS=https://your-project.vercel.app,https://www.yourdomain.com,http://localhost:5173

# Email (optional - required only if contact/application mail features are used)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
FROM_EMAIL=BozTech Atolye <noreply@boztech.com>
